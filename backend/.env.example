# Data directory for SQLite DB, uploads, and Sia keys.
# In Docker this is set to /app/data; locally it defaults to ./data (relative to backend/).
# DATA_DIR=./data

# Path for SQLite database file (default: <DATA_DIR>/files.db)
# FILE_DB_PATH=./data/files.db
