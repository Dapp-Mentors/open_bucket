# Backend
PORT=4000
INNGEST_EVENT_KEY=local
INNGEST_BASE_URL=http://localhost:8288
SIA_INDEXER_URL=https://sia.storage
SIA_APP_ID=6f70656e6275636b657400000000000000000000000000000000000000000000
