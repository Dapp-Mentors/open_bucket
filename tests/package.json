{
  "name": "openbucket-tests",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "rootDir": "..",
    "testMatch": ["<rootDir>/tests/**/*.test.ts"],
    "testEnvironment": "node",
    "transform": {
      "^.+\\.tsx?$": ["<rootDir>/tests/node_modules/ts-jest", {
        "tsconfig": {
          "module": "commonjs",
          "esModuleInterop": true,
          "resolveJsonModule": true,
          "strict": false,
          "paths": {
            "@/*": ["frontend/src/*"]
          },
          "baseUrl": "."
        }
      }]
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/frontend/src/$1"
    },
    "moduleDirectories": ["tests/node_modules", "node_modules"],
    "collectCoverageFrom": [
      "frontend/src/lib/storage.ts",
      "frontend/src/types/index.ts"
    ],
    "coveragePathIgnorePatterns": []
  },
  "dependencies": {
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/sql.js": "^1.4.9",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.3",
    "typescript": "^5.5.2"
  }
}